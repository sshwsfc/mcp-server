{
  "name": "@airiot/tools",
  "version": "1.0.0",
  "description": "MCP server and CLI for AIRIOT IoT platform",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "airiot-mcp-server": "dist/index.js",
    "airiot": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "cli": "node dist/cli/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "airiot",
    "iot",
    "model-context-protocol",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "axios": "^1.7.9",
    "commander": "^14.0.3",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
